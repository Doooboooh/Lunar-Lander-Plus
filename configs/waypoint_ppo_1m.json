  "model_kwargs": {
    "learning_rate": 1e-4,
    "n_steps": 1024,
    "n_epochs": 4,
    "batch_size": 64,
    "gamma": 0.99,
    "gae_lambda": 0.98,
    "clip_range": 0.2,
    "ent_coef": 0.01,
    "vf_coef": 0.5,
    "max_grad_norm": 0.5,
    "device": "auto"
  }
}
