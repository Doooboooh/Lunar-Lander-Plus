{
  "name": "obstacle_dqn_random",
  "env_id": "ObstacleLunarLander-v0",
  "algorithm": "dqn",
  "seed": 42,
  "total_timesteps": 300000,
  "eval_episodes": 10,
  "env_kwargs": {"random_obstacles": true},
  "vec_normalize": {
    "enabled": true,
    "norm_obs": true,
    "norm_reward": false,
    "clip_obs": 10.0
  },
  "model_kwargs": {
    "learning_rate": 1e-4,
    "buffer_size": 100000,
    "learning_starts": 1000,
    "batch_size": 64,
    "gamma": 0.99,
    "target_update_interval": 500,
    "exploration_fraction": 0.2,
    "exploration_final_eps": 0.05
  }
}
